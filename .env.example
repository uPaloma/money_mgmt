# Copy to .env and fill in. 
#   cp .env.example .env  &&  chmod 600 .env
# Load into your shell before running scripts:
#   set -a; . ./.env; set +a

# Application ID (UUID) from the Enable Banking Control Panel after you
# register your application.
EB_APP_ID=

# Path to the RSA private key that pairs with the public key you uploaded.
# Default already points at secrets/eb_private.pem, override only if needed.
# EB_PRIVATE_KEY=/home/paloma/proj/money_mgmt/secrets/eb_private.pem

# Redirect URL you whitelisted during registration. For this SSH-only setup
# you never actually serve it — you copy the `code` from the browser by hand.
EB_REDIRECT_URL=https://localhost/callback
